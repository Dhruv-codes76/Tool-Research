# Copy to .env and fill in. Do NOT commit the real .env.

# --- Database (PostgreSQL) ---
# Pooled connection — runtime queries + seed
DATABASE_URL="postgresql://user:password@host:6543/postgres?pgbouncer=true"
# Direct connection — migrations only
DIRECT_URL="postgresql://user:password@host:5432/postgres"

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
# Service role — server-only. Required for admin invites (inviteUserByEmail) and seed self-invite.
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# --- RBAC / admin invites ---
# The single primary admin, seeded once via self-invite. Cannot be removed in-app.
PRIMARY_ADMIN_EMAIL="owner@example.com"
# Public base URL used server-side to build invite/reset redirect links
# (server actions have no window.origin). No trailing slash.
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# --- GitHub (tool metadata) ---
GITHUB_PERSONAL_ACCESS_TOKEN="ghp_xxx"

# --- Email (Resend) ---
RESEND_API_KEY="re_xxx"

// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  role          String    @default("USER")
  tools         Tool[]
}

model Platform {
  id    String @id @default(cuid())
  name  String @unique
  tools Tool[]
}

model ToolType {
  id    String @id @default(cuid())
  name  String @unique
  tools Tool[]
}



model Tool {
  id          String   @id @default(cuid())
  name        String
  description String
  repoUrl     String   @unique
  imageUrl    String?
  stars         Int        @default(0)
  forks         Int        @default(0)
  issues        Int        @default(0)
  lastUpdate    DateTime   @default(now())
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  status        String     @default("ACTIVE")
  lastFetchedAt DateTime   @default(now())
  
  aboutText       String?
  version         String?
  license         String?
  installCommand  String?
  heroImageUrl    String?
  galleryImages   String?  @default("[]")
  galleryLayout   String?  @default("16:9")
  features        String?  @default("[]")

  author          String?
  since           String?
  websiteUrl      String?

  userId        String
  user          User       @relation(fields: [userId], references: [id])
  platforms     Platform[]
  toolTypes     ToolType[]
}

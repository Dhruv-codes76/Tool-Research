generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id             String    @id @default(cuid())
  name           String?
  email          String?   @unique
  emailVerified  DateTime?
  image          String?
  role           String    @default("USER")
  acceptedAt     DateTime?
  invitedAt      DateTime?
  invitedById    String?
  isPrimaryAdmin Boolean   @default(false)
  status         String    @default("ACTIVE")
  tools          Tool[]
  savedTools     SavedTool[]
  invitedBy      User?     @relation("AdminInvites", fields: [invitedById], references: [id])
  invitedAdmins  User[]    @relation("AdminInvites")
}

model Platform {
  id          String  @id @default(cuid())
  name        String  @unique
  description String?
  tools       Tool[]  @relation("PlatformToTool")
}

model ToolType {
  id          String  @id @default(cuid())
  name        String  @unique
  description String?
  tools       Tool[]  @relation("ToolToToolType")
}

model Tool {
  id               String       @id @default(cuid())
  name             String
  description      String
  repoUrl          String       @unique
  imageUrl         String?
  stars            Int          @default(0)
  forks            Int          @default(0)
  issues           Int          @default(0)
  lastUpdate       DateTime     @default(now())
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  status           String       @default("ACTIVE")
  lastFetchedAt    DateTime     @default(now())
  aboutText        String?
  version          String?
  license          String?
  installCommand   String?
  heroImageUrl     String?
  galleryImages    String?      @default("[]")
  galleryLayout    String?      @default("16:9")
  features         String?      @default("[]")
  author           String?
  authorUrl        String?
  since            String?
  websiteUrl       String?
  downloadUrl      String?
  userId           String
  downloadAssets   String?      @default("[]")
  metaTitle        String?
  metaDescription  String?
  rejectionReason  String?
  submittedByEmail String?
  publishedAt      DateTime?
  // JSON snapshot of the values the SUBMITTER originally provided (name,
  // description, images, categories…). Written once at submission time and
  // never mutated after. The submitter dashboard diffs this against the live
  // Tool to show exactly which fields the admin edited before publishing.
  submissionSnapshot String?
  // SEO: slug is the ONLY public URL identifier for a tool. Unique so no two
  // tools can collide. Kept nullable at the DB level (Postgres treats NULLs as
  // distinct, so the constraint is safe on legacy rows) — presence is enforced
  // in the app layer (both submit forms + server actions always set a slug).
  slug             String?      @unique
  user             User         @relation(fields: [userId], references: [id])
  changes          ToolChange[]
  savedBy          SavedTool[]
  platforms        Platform[]   @relation("PlatformToTool")
  toolTypes        ToolType[]   @relation("ToolToToolType")
}

/**
 * A user's wishlist entry — one row per (user, tool). Login-required, DB-backed.
 * Deleting the tool or user cascades so no orphan saves remain.
 */
model SavedTool {
  id        String   @id @default(cuid())
  userId    String
  toolId    String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tool      Tool     @relation(fields: [toolId], references: [id], onDelete: Cascade)

  @@unique([userId, toolId])
  @@index([userId])
}

model ToolChange {
  id         String    @id @default(cuid())
  toolId     String
  field      String
  oldValue   String?
  newValue   String
  status     String    @default("PENDING")
  source     String    @default("CRON")
  detectedAt DateTime  @default(now())
  resolvedAt DateTime?
  tool       Tool      @relation(fields: [toolId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([toolId])
}

model AuditLog {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())
  actorId     String?
  actorEmail  String?
  actorRole   String?
  action      String
  status      String   @default("SUCCESS")
  targetType  String?
  targetId    String?
  targetLabel String?
  metadata    String?
  ip          String?
  userAgent   String?

  @@index([createdAt])
  @@index([actorId])
  @@index([action])
  @@index([targetType, targetId])
}
